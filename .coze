[project]
requires = ["nodejs-24"]

[dev]
build = ["pnpm", "install"]
run = ["bash", "/workspace/projects/start.sh"]

[deploy]
build = ["bash", "-c", "pnpm install && pnpm --filter @ai-commerce-ops/shared build && pnpm --filter @ai-commerce-ops/connectors build && pnpm --filter api build && pnpm --filter web build"]
run = ["bash", "-c", "cd /workspace/projects/apps/api && node dist/main.js & cd /workspace/projects && npx serve apps/web/dist -l 5000"]
